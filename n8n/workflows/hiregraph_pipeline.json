    {
      "parameters": {
        "jsCode": "const payload = $json;\nconst jobs = Array.isArray(payload)\n  ? payload\n  : Array.isArray(payload.jobs)\n    ? payload.jobs\n    : Array.isArray(payload.data)\n      ? payload.data\n      : [];\n\nreturn jobs\n  .filter((job) => job && job.url && (job.raw_payload || job.html))\n  .map((job) => ({\n    json: {\n      url: job.url,\n      raw_payload: job.raw_payload || job.html,\n      source_id: job.source_id || 'wellfound',\n      payload_format: job.payload_format || 'text'\n    }\n  }));"
      },
      "id": "normalize-scraper-response",
      "name": "Normalize Scraper Response",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        940,
        260
