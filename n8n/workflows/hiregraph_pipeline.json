        "jsonBody": "={\n  \"source_id\": $json.source_id || \"wellfound\",\n  \"source_record_locator\": $json.url,\n  \"payload_format\": $json.payload_format || \"text\",\n  \"raw_payload\": $json.raw_payload,\n  \"ingestion_status\": \"success\",\n  \"observed_at\": $now.toISO(),\n  \"fetched_at\": $now.toISO()\n}",
        "options": {
          "response": {
            "response": {
              "fullResponse": false
            }
          }
        }
