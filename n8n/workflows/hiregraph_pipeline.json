        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "{\n  \"source\": \"wellfound\",\n  \"limit\": 5\n}",
        "options": {
          "response": {
            "response": {
              "fullResponse": false
            }
          },
          "timeout": 300000
        }
      },
      "id": "trigger-scraper",
